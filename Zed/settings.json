{
	"disable_ai": true,
	"colorize_brackets": true,
	"toolbar": {
		"agent_review": false,
	},
	"redact_private_values": true,
	"edit_predictions": {
		"enabled_in_text_threads": false,
		"provider": "none",
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false,
	},
	"theme": "zed_color_theme_00m3_001",
	"agent": {
		"cancel_generation_on_terminal_stop": false,
		"expand_edit_card": false,
		"expand_terminal_card": false,
		"enable_feedback": false,
		"enabled": false,
	},

	"auto_install_extensions": {
		"html": false,
		"JavaScript": false,
		"Python": false,
		"PHP": false,
		"Java": false,
		"C": false,
		"C++": false,
	},

	"buffer_font_family": "Fira Code",
	"buffer_font_size": 20,
	"buffer_font_weight": 400,
	"ui_font_family": "Atkinson Hyperlegible Next",
	"ui_font_size": 24,
	"ui_font_weight": 400,
	"agent_ui_font_size": 16,
	"buffer_font_features": {
		"calt": false,
		"liga": false,
	},

	"diagnostics": {
		"inline": {
			"enabled": false,
		},
	},

	"project_panel": {
		"default_width": 600,
		"entry_spacing": "comfortable",
		"git_status": true,
		"auto_fold_dirs": false,
		"show_diagnostics": "all",
		"indent_guides": {
			"show": "always",
		},
	},
	"outline_panel": {
		"default_width": 600,
		"auto_fold_dirs": true,
	},
	"git_panel": {
		"tree_view": false,
		"default_width": 600,
	},
	"collaboration_panel": {
		"button": false,
		"dock": "left",
		"default_width": 600,
	},
	"notification_panel": {
		"button": true,
		"dock": "right",
		"default_width": 600,
	},

	"cursor_shape": "block",
	"hard_tabs": true,
	"tab_size": 8,
	"preferred_line_length": 80,
	"bottom_dock_layout": "left_aligned",
	"when_closing_with_no_tabs": "keep_window_open",
	"use_system_path_prompts": true,
	"use_system_prompts": false,
	"hide_mouse": "on_typing_and_movement",
	"snippet_sort_order": "top",
	"current_line_highlight": "gutter",
	"show_completions_on_input": false,
	"show_edit_predictions": false,
	"show_whitespaces": "selection",
	"title_bar": {
		"show_user_menu": true,
		"show_sign_in": false,
		"show_onboarding_banner": false,
		"show_branch_icon": true,
	},
	"scrollbar": {
		"show": "always",
		"axes": {
			"horizontal": false,
		},
	},
	"middle_click_paste": false,
	"double_click_in_multibuffer": "open",
	"indent_guides": {
		"enabled": true,
		"line_width": 2,
		"active_line_width": 2,
		"coloring": "indent_aware",
	},
	"scroll_beyond_last_line": "vertical_scroll_margin",
	"vertical_scroll_margin": 1,
	"search": {
		"case_sensitive": true,
	},
	"inlay_hints": {
		"show_type_hints": true,
		"show_parameter_hints": true,
		"show_other_hints": true,
		"show_background": true,
	},
	"tabs": {
		"git_status": true,
		"show_close_button": "hover",
		"file_icons": false,
		"show_diagnostics": "all",
	},
	"git": {
		"inline_blame": {
			"enabled": false,
		},
	},
	"tab_bar": {
		"show_pinned_tabs_in_separate_row": false,
		"show_tab_bar_buttons": true,
		"show": true,
		"show_nav_history_buttons": false,
	},
	"preview_tabs": {
		"enabled": true,
		"enable_preview_from_file_finder": true,
		"enable_keep_preview_on_code_navigation": true,
	},
	"soft_wrap": "bounded",
	"terminal": {
		"default_height": 900,
		"blinking": "on",
		"button": false,
		"scrollbar": {
			"show": "always",
		},
		"max_scroll_history_lines": 500,
	},
	"jupyter": {
		"enabled": false,
	},
	"minimap": {
		"show": "always",
		"thumb_border": "full",
	},

	"languages": {
		"HTML": {
			"tab_size": 2,
		},
	},
}
